generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  image     String?  // for catalog grid
  createdAt DateTime @default(now())

  products  Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  sku         String?
  description String

  // Images (2 images as per requirement)
  image1      String
  image2      String?

  // Benefits (bullet points)
  benefits    Json
  
  isActive Boolean @default(true)

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  role     Role   @default(ADMIN)
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  country   String
  quantity  String
  product   String
  message   String

  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
}