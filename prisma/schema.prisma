generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  image     String?  // for catalog grid
  createdAt DateTime @default(now())

  products  Product[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  sku           String?

  tagline       String?   // small line under title
  shortDesc     String?   // intro paragraph
  description   String    // full overview

  // Images
  image1        String    // main product image
  image2        String?   // gallery image
  image3        String?   // header background (16:9)

  // Content
  features      Json?     // bullet points
  specifications Json?    // technical table

  isActive      Boolean   @default(true)

  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  role     Role   @default(ADMIN)
}

model Inquiry {
  id            String   @id @default(cuid())
  fullName      String
  role          String
  email         String
  phone         String
  organisation  String
  helpType      String
  message       String
  createdAt     DateTime @default(now())
}

enum Role {
  ADMIN
}